---
import PortfolioItem from "./PortfolioItem.astro";
import projects from "../data/projects.json";
---

<section id="portfolio">
  <h2 class="font-roboto text-white text-2xl font-bold pb-4">
    Here are some of my projects:
  </h2>

  <ul
    class="grid md:grid-cols-3 sm:grid-cols-2 xs:grid-cols-1 gap-4 auto-rows-auto"
  >
    {projects.map((project: any) => <PortfolioItem {...project} />)}
  </ul>
</section>
